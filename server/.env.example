# ==== Server ====
NODE_ENV=development
PORT=3000

# ==== Database (PostgreSQL) ====
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=harth
# Production alternative:
# DATABASE_URL=postgres://user:pass@host:5432/dbname
# DB_SSL=true

# ==== Auth ====
# MUST be at least 32 characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ==== Admin bootstrap (created on first boot if no admin exists) ====
ADMIN_EMAIL=admin@harth.com
ADMIN_PASSWORD=admin123

# ==== Uploads ====
# UPLOAD_DIR=./uploads
UPLOAD_MAX_BYTES=5242880   # 5 MB
# PUBLIC_BASE_URL=https://api.harth.com

# ==== Stripe (Phase 2) ====
# Leave blank in development to use the built-in mock payment flow.
# In production you MUST set STRIPE_SECRET_KEY or explicitly opt into mocks.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=omr
# ALLOW_MOCK_PAYMENTS=false

# ==== Email / SMTP (Phase 4) ====
# ALL OPTIONAL. If any of SMTP_HOST/USER/PASSWORD is missing, email
# notifications are silently skipped and logged as 'not_configured' in
# notifications_log. Nothing else breaks.
#
# Examples:
#   Gmail app-password:   SMTP_HOST=smtp.gmail.com  SMTP_PORT=587
#   SendGrid:             SMTP_HOST=smtp.sendgrid.net  SMTP_PORT=587  SMTP_USER=apikey
#   Mailtrap (dev):       SMTP_HOST=sandbox.smtp.mailtrap.io  SMTP_PORT=2525
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@harth.com

# ==== Twilio / WhatsApp / SMS (Phase 4) ====
# ALL OPTIONAL. Same fallback behaviour as SMTP — missing vars disable
# WhatsApp/SMS without breaking anything else.
#
# TWILIO_WHATSAPP_FROM must be a WhatsApp-enabled Twilio number in E.164
# format, e.g. +14155238886 (sandbox) or your approved business number.
# The service auto-prefixes 'whatsapp:' for you.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TWILIO_SMS_FROM=

# ==== Phone OTP verification (Phase 5) ====
# Requires TWILIO_ACCOUNT_SID/TWILIO_AUTH_TOKEN/TWILIO_SMS_FROM above to
# actually deliver SMS. Without them, codes are logged to the server
# console in development (never in production).
PHONE_OTP_LENGTH=6              # 4 or 6 only; anything else falls back to 6
PHONE_OTP_EXPIRY_MINUTES=5
PHONE_OTP_MAX_ATTEMPTS=5
PENDING_REGISTRATION_TTL_MINUTES=30
