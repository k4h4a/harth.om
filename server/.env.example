# ==== Server ====
NODE_ENV=development
PORT=3000

# ==== Database (PostgreSQL) ====
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=harth
# Production alternative:
# DATABASE_URL=postgres://user:pass@host:5432/dbname
# DB_SSL=true

# ==== Auth ====
# MUST be at least 32 characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ==== Admin bootstrap (created on first boot if no admin exists) ====
ADMIN_EMAIL=admin@harth.com
ADMIN_PASSWORD=admin123

# ==== Uploads ====
# UPLOAD_DIR=./uploads
UPLOAD_MAX_BYTES=5242880   # 5 MB
# PUBLIC_BASE_URL=https://api.harth.com

# ==== Stripe (Phase 2) ====
# Leave blank in development to use the built-in mock payment flow.
# In production you MUST set STRIPE_SECRET_KEY or explicitly opt into mocks.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=omr
# ALLOW_MOCK_PAYMENTS=false

# ==== Email / SMTP (Phase 4) ====
# ALL OPTIONAL. If any of SMTP_HOST/USER/PASS is missing, email
# notifications are silently skipped and logged as 'not_configured' in
# notifications_log. Nothing else breaks.
#
# Also the delivery channel for registration OTP codes (Phase 5) — without
# these set, registration OTP codes are logged to the server console in
# development only (never in production).
#
# Examples:
#   Gmail app-password:   SMTP_HOST=smtp.gmail.com  SMTP_PORT=587
#   SendGrid:             SMTP_HOST=smtp.sendgrid.net  SMTP_PORT=587  SMTP_USER=apikey
#   Mailtrap (dev):       SMTP_HOST=sandbox.smtp.mailtrap.io  SMTP_PORT=2525
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@harth.com

# ==== Twilio / WhatsApp (Phase 4) ====
# ALL OPTIONAL. Used only for order/rental WhatsApp notifications — NOT for
# account verification (that's email OTP above). Missing vars disable
# WhatsApp notifications without breaking anything else.
#
# TWILIO_WHATSAPP_FROM must be a WhatsApp-enabled Twilio number in E.164
# format, e.g. +14155238886 (sandbox) or your approved business number.
# The service auto-prefixes 'whatsapp:' for you.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# ==== Registration email OTP (Phase 5) ====
REGISTRATION_OTP_EXPIRY_MINUTES=5
REGISTRATION_OTP_MAX_ATTEMPTS=5
PENDING_REGISTRATION_TTL_MINUTES=30

# ==== Google OAuth ("Sign in with Google") ====
# Create an OAuth 2.0 Client ID at https://console.cloud.google.com/apis/credentials
# (Application type: Web application). Add GOOGLE_CALLBACK_URL below as an
# "Authorized redirect URI" there — it must match exactly.
# ALL OPTIONAL. If left blank, the Google button shows a clear error instead
# of breaking the rest of the site.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback
